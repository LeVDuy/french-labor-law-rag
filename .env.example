# Droit du travail français RAG — Variables d'environnement
# Copiez ce fichier dans .env et renseignez vos valeurs.
# Toutes les valeurs ci-dessous sont des valeurs par défaut ; ne modifiez que celles dont vous avez besoin.

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=french_law_hybrid

# Embedding Models
DENSE_MODEL_NAME=BAAI/bge-m3
SPARSE_MODEL_NAME=Qdrant/bm25

# Reranker
RERANKER_MODEL_NAME=antoinelouis/crossencoder-camembert-base-mmarcoFR

# Chunking 
CHILD_CHUNK_SIZE=1500
CHILD_CHUNK_OVERLAP=250

# LLM 
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=local-model
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1500

# Retriever
HYBRID_SEARCH_K=60
RERANKER_TOP_N=7
FINAL_TOP_K=3

# Groq API 
GROQ_API_KEY=

# Légifrance API 
LEGIFRANCE_CLIENT_ID=
LEGIFRANCE_CLIENT_SECRET=

# Device 
DEVICE=mps
EMBEDDING_BATCH_SIZE=8
